    "@opennextjs/cloudflare": "^1.17.1",
    "@prisma/adapter-d1": "^6.19.2",
    "@prisma/client": "^6.19.2",
    "better-auth": "^1.5.5",
    "clsx": "^2.1.1",
    "framer-motion": "^12.34.3",
    "lucide-react": "^0.563.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "resend": "^6.9.3",
    "tailwind-merge": "^3.4.0",
